# --- 02_TDA_Betti_Curves.ipynb (UPDATED FOR REAL DATASET) ---
import networkx as nx
import numpy as np
import matplotlib.pyplot as plt
import pickle
import json
import os
from gtda.graphs import GraphGeodesicDistance
from gtda.homology import VietorisRipsPersistence
from gtda.diagrams import BettiCurve

# =====================================================================
# 1. LOAD BACKBONE GRAPH FROM PHASE 1
# =====================================================================
file_path = 'backbone_graph.pkl'
if not os.path.exists(file_path):
    raise FileNotFoundError("Run '01_Data_Curation_KG.ipynb' first to generate the backbone graph!")

with open(file_path, 'rb') as f:
    G_backbone = pickle.load(f)

print(f"Loaded Backbone Graph: {G_backbone.number_of_nodes()} nodes, {G_backbone.number_of_edges()} edges.")

# To compute Geodesic (shortest-path) distances, the graph must be fully connected.
# We will extract the Largest Connected Component (LCC) to avoid infinite distances.
connected_components = list(nx.connected_components(G_backbone))
largest_cc = max(connected_components, key=len)
G_core = G_backbone.subgraph(largest_cc).copy()

print(f"Extracted Largest Connected Component: {G_core.number_of_nodes()} nodes.")

# Convert to dense Adjacency Matrix
adj_matrix = nx.to_numpy_array(G_core)

# =====================================================================
# 2. TDA: UNWEIGHTED GEODESIC FILTRATION
# =====================================================================
print("Computing Unweighted Geodesic Distance Matrix...")
ggd = GraphGeodesicDistance(directed=False, unweighted=True)
X_distance = ggd.fit_transform([adj_matrix])

# =====================================================================
# 3. COMPUTE PERSISTENT HOMOLOGY
# =====================================================================
print("Computing Persistent Homology (H0 and H1)...")
# We compute 0-dimensional (components) and 1-dimensional (loops/synergy) features
vr = VietorisRipsPersistence(metric='precomputed', homology_dimensions=[0, 1])
diagrams = vr.fit_transform(X_distance)
diagram = diagrams[0] # Extract the diagram for our single graph

# --- GENERATE FIGURE 3: PERSISTENCE DIAGRAM ---
plt.figure(figsize=(10, 8), dpi=300)

h0 = diagram[diagram[:, 2] == 0]
h1 = diagram[diagram[:, 2] == 1]

# Plot H0 (Red) and H1 (Blue)
plt.scatter(h0[:, 0], h0[:, 1], c='#e74c3c', label='H0 (Connected Components)', s=60, alpha=0.5, edgecolors='none')
plt.scatter(h1[:, 0], h1[:, 1], c='#3498db', label='H1 (Synergy Loops)', s=60, marker='^', alpha=0.6, edgecolors='none')

# Draw Diagonal Line (Birth = Death)
max_val = np.max(diagram[:, 1]) + 1
plt.plot([-1, max_val], [-1, max_val], 'k--', alpha=0.4)

plt.xlim(-0.2, max_val)
plt.ylim(-0.2, max_val)
plt.xlabel("Birth Radius (Graph Hops)", fontsize=14)
plt.ylabel("Death Radius (Graph Hops)", fontsize=14)
plt.title("Figure 3: Persistence Diagram (Geodesic Filtration)", fontsize=16, fontweight='bold')
plt.legend(fontsize=12, loc='lower right')
plt.grid(True, linestyle=':', alpha=0.6)

plt.savefig('Fig3_Persistence_Diagram_EN.png', bbox_inches='tight')
print("-> Saved Figure 3 as 'Fig3_Persistence_Diagram_EN.png'")
plt.show()

# =====================================================================
# 4. VECTORIZATION: BETTI CURVES
# =====================================================================
print("Vectorizing Topological Features into Betti Curves...")
N_BINS = 100
bc = BettiCurve(n_bins=N_BINS) 
betti_curves = bc.fit_transform(diagrams)

betti_0 = betti_curves[0, 0, :]
betti_1 = betti_curves[0, 1, :]

# --- GENERATE FIGURE 4: MACROSCOPIC BETTI CURVES ---
plt.figure(figsize=(12, 6), dpi=300)
# Generate x-axis points based on the max filtration radius
x_axis = np.linspace(0, np.max(diagram[:, 1]), N_BINS)

plt.plot(x_axis, betti_0, c='#e74c3c', label='Betti-0 (Number of Components)', linewidth=3)
plt.fill_between(x_axis, betti_0, color='#e74c3c', alpha=0.15)

plt.plot(x_axis, betti_1, c='#3498db', label='Betti-1 (Number of Synergy Loops)', linewidth=3)
plt.fill_between(x_axis, betti_1, color='#3498db', alpha=0.15)

plt.xlabel("Filtration Radius $\epsilon$ (Geodesic Distance / Hops)", fontsize=14)
plt.ylabel("Betti Number (Feature Count)", fontsize=14)
plt.title("Figure 4: Macroscopic Betti Curves", fontsize=16, fontweight='bold')
plt.legend(fontsize=12)
plt.grid(True, linestyle=':', alpha=0.6)

plt.savefig('Fig4_Betti_Curves_EN.png', bbox_inches='tight')
print("-> Saved Figure 4 as 'Fig4_Betti_Curves_EN.png'")
plt.show()

# =====================================================================
# 5. EXPORT PROCESSED BETTI TENSORS TO JSON
# =====================================================================
betti_data = {
    "metadata": {
        "description": "Pre-computed Betti Tensors for Vi-TCM Explorer API",
        "filtration_type": "Unweighted Geodesic Distance",
        "threshold_tau": 2,
        "n_bins": N_BINS,
        "max_radius": float(np.max(diagram[:, 1])),
        "total_h1_loops_detected": len(h1)
    },
    "core_network": {
        "betti_0": betti_0.tolist(),
        "betti_1": betti_1.tolist()
    }
}

json_file_name = 'processed_betti_tensors.json'
with open(json_file_name, 'w', encoding='utf-8') as f:
    json.dump(betti_data, f, ensure_ascii=False, indent=4)

print(f"\nSuccess! Exported Topo-tensors to: '{json_file_name}'")
print("All phases completed. You can now download the PNG figures and the JSON file from the Colab file explorer.")
