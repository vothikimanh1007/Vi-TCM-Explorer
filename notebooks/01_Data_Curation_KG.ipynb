# --- 01_Data_Curation_KG.ipynb (UPDATED TO USE REAL CSV DATA) ---
import networkx as nx
import matplotlib.pyplot as plt
import pandas as pd
import numpy as np
import pickle
import os

# =====================================================================
# 1. LOAD REAL DATASET: ViThuoc_final.csv
# =====================================================================
file_path = 'ViThuoc_final.csv'

# Check if file exists in Colab
if not os.path.exists(file_path):
    raise FileNotFoundError(f"'{file_path}' not found! Please click the folder icon on the left sidebar in Colab and upload 'ViThuoc_final.csv'.")

# Read the CSV file
df = pd.read_csv(file_path)

print(f"Dataset loaded successfully! Total herbs found: {len(df)}")
print("Preview of raw data:")
print(df.head(3))
print("-" * 50)

# Parse the DataFrame into the format required for the Knowledge Graph.
# NOTE: Please change 'Herb', 'Properties', 'Meridians' below to match 
# the EXACT column headers in your CSV file (e.g., 'Ten_Thuoc', 'Tinh_Vi', 'Quy_Kinh').
tm_data = []
for index, row in df.iterrows():
    # Adjust these column names if your CSV uses different headers
    herb_name = str(row['Herb']).strip() 
    
    # Split the comma-separated strings into lists and remove extra spaces
    properties_raw = str(row['Properties']) if pd.notna(row['Properties']) else ""
    meridians_raw = str(row['Meridians']) if pd.notna(row['Meridians']) else ""
    
    properties = [p.strip() for p in properties_raw.split(',') if p.strip()]
    meridians = [m.strip() for m in meridians_raw.split(',') if m.strip()]
    
    tm_data.append({
        "herb": herb_name,
        "properties": properties,
        "meridians": meridians
    })

# =====================================================================
# 2. CONSTRUCT TRIPARTITE KNOWLEDGE GRAPH
# =====================================================================
G_tripartite = nx.Graph()

for item in tm_data:
    herb = item["herb"]
    G_tripartite.add_node(herb, type="Herb")
    
    for prop in item["properties"]:
        prop_node = f"Prop:{prop}"
        G_tripartite.add_node(prop_node, type="Property")
        G_tripartite.add_edge(herb, prop_node)
        
    for mer in item["meridians"]:
        mer_node = f"Meridian:{mer}"
        G_tripartite.add_node(mer_node, type="Meridian")
        G_tripartite.add_edge(herb, mer_node)

print(f"Tripartite Graph Created: {G_tripartite.number_of_nodes()} nodes, {G_tripartite.number_of_edges()} edges.")

# --- GENERATE FIGURE 1: TRIPARTITE KNOWLEDGE GRAPH ---
plt.figure(figsize=(14, 10), dpi=300)
pos = nx.spring_layout(G_tripartite, seed=42, k=0.15) # 'k' adjusts node spacing

color_map = []
node_sizes = []
for node, attr in G_tripartite.nodes(data=True):
    if attr['type'] == 'Herb':
        color_map.append('#2ecc71') # Emerald
        node_sizes.append(300)      # Smaller size since there are 700+ herbs
    elif attr['type'] == 'Property':
        color_map.append('#3498db') # Blue
        node_sizes.append(200)
    else:
        color_map.append('#e74c3c') # Red
        node_sizes.append(200)

nx.draw(G_tripartite, pos, with_labels=False, node_color=color_map, 
        node_size=node_sizes, edge_color='#bdc3c7', alpha=0.8)

plt.title("Figure 1: Tripartite Knowledge Graph of TM (Full Dataset)", fontsize=16, fontweight='bold')
plt.savefig('Fig1_Core_Knowledge_Graph_EN.png', bbox_inches='tight')
plt.show()


# =====================================================================
# 3. EXTRACT THRESHOLD-BASED SIMILARITY BACKBONE (Tau >= 2)
# =====================================================================
TAU = 2
G_backbone = nx.Graph()
herbs = [n for n, attr in G_tripartite.nodes(data=True) if attr['type'] == 'Herb']

print(f"Extracting similarity backbone with Threshold (Tau) >= {TAU}...")

for i in range(len(herbs)):
    G_backbone.add_node(herbs[i])
    for j in range(i + 1, len(herbs)):
        # Find shared properties and meridians
        neighbors_i = set(G_tripartite.neighbors(herbs[i]))
        neighbors_j = set(G_tripartite.neighbors(herbs[j]))
        shared_features = neighbors_i.intersection(neighbors_j)
        
        # Apply strict intersection threshold
        if len(shared_features) >= TAU:
            G_backbone.add_edge(herbs[i], herbs[j], weight=len(shared_features))

# Remove isolated nodes (herbs that share < 2 properties with any other herb)
isolated_nodes = list(nx.isolates(G_backbone))
G_backbone.remove_nodes_from(isolated_nodes)

print(f"Backbone Graph Created: {G_backbone.number_of_nodes()} nodes, {G_backbone.number_of_edges()} edges.")

# --- GENERATE FIGURE 2: SIMILARITY BACKBONE ---
plt.figure(figsize=(14, 10), dpi=300)
pos_bb = nx.spring_layout(G_backbone, seed=42, k=0.15)
edges = G_backbone.edges()
weights = [G_backbone[u][v]['weight'] * 0.5 for u, v in edges] # Scaled down for dense graph

nx.draw(G_backbone, pos_bb, with_labels=False, node_color='#9b59b6', 
        node_size=150, width=weights, edge_color='#7f8c8d', alpha=0.7)

plt.title(f"Figure 2: Herb-Herb Similarity Backbone (Tau >= {TAU})", fontsize=16, fontweight='bold')
plt.savefig('Fig2_Herb_Similarity_Network_EN.png', bbox_inches='tight')
plt.show()


# =====================================================================
# 4. EXPORT BACKBONE FOR TDA NOTEBOOK
# =====================================================================
with open('backbone_graph.pkl', 'wb') as f:
    pickle.dump(G_backbone, f)
print("Graph processing complete. Exported 'backbone_graph.pkl' and Figures 1 & 2.")
